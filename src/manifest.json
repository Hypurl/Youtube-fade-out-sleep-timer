{
  "manifest_version": 3,
  "name": "BetterSleepTimer",
  "version": "0.1.0",
  "description": "Gently fades YouTube volume before pausing.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://www.youtube.com/*"],
  "background": {
    "service_worker": "background/index.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content/index.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
