{
  "manifest_version": 3,
  "name": "Sleep Fade",
  "version": "0.1.0",
  "description": "Gently fades YouTube volume before pausing.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
